---
import { Image, getImage } from 'astro:assets';
import rawHeroBg from '../assets/high-voltage-transformer.avif';
import transformerImg from '../assets/transformer-and-switchgear.png';
import generatorImg from '../assets/generator-and-substation.png';
import conditionImg from '../assets/condition-monitoring-two.jpg';
import motorImg from '../assets/ac-dc-motor-rewinding.png';

const optimizedBg = await getImage({
  src: rawHeroBg,
  format: 'avif',
  width: 1920,
  height: 1080,
  quality: 70,
});
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Uncut Electro Mechanical Engineering | Industrial Repairs & Condition Monitoring</title>
  
  <!-- Preload the Hero LCP Background Image -->
  <link rel="preload" as="image" href={optimizedBg.src} type="image/avif" fetchpriority="high" />

  <!-- Inline Full Production CSS -->
  <style>
    :root {
      --primary: #0f172a;
      --accent: #f97316;
      --accent-hover: #ea580c;
      --text-dark: #1e293b;
      --text-light: #94a3b8;
      --bg-dark: #090d16;
      --bg-card: #111827;
      --white: #ffffff;
      --black: #000000;
      --border: #1e293b;
      --font-heading: 'Barlow Condensed', sans-serif;
      --font-sans: 'Plus Jakarta Sans', sans-serif;
    }

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: var(--font-sans);
      color: var(--white);
      background-color: var(--bg-dark);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }

    .container {
      width: 100%;
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    /* Header & Prominent Logo Fix */
    .site-header {
      background: var(--black);
      padding: 1.25rem 0;
      border-bottom: 3px solid var(--accent);
    }

    .header-container {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .site-logo {
      width: 220px;
      height: auto;
      max-height: 55px;
      object-fit: contain;
      display: block;
    }

    /* Hero Section */
    .hero-section {
      position: relative;
      background-size: cover;
      background-position: center;
      padding: 7rem 0 6rem;
      color: var(--white);
      text-align: left;
    }

    .hero-section::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, rgba(9,13,22,0.95) 0%, rgba(9,13,22,0.82) 60%, rgba(9,13,22,0.5) 100%);
      z-index: 1;
    }

    .hero-container {
      position: relative;
      z-index: 2;
      max-width: 800px;
      margin: 0 auto 0 0;
    }

    .hero-badge {
      display: inline-block;
      background: var(--accent);
      color: var(--white);
      font-family: var(--font-heading);
      font-size: 0.95rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      padding: 0.35rem 0.85rem;
      border-radius: 4px;
      margin-bottom: 1.25rem;
    }

    .hero-section h1 {
      font-family: var(--font-heading);
      font-size: clamp(2.5rem, 5vw, 4rem);
      font-weight: 700;
      line-height: 1.1;
      text-transform: uppercase;
      margin-bottom: 1.25rem;
      letter-spacing: 0.5px;
    }

    .hero-section p {
      font-size: clamp(1.1rem, 1.5vw, 1.15rem);
      color: #cbd5e1;
      margin-bottom: 2rem;
      line-height: 1.7;
    }

    .hero-buttons {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .btn-primary {
      background: var(--accent);
      color: var(--white);
      padding: 0.85rem 1.75rem;
      font-weight: 600;
      border-radius: 4px;
      text-decoration: none;
      transition: background 0.2s;
    }

    .btn-primary:hover {
      background: var(--accent-hover);
    }

    .btn-secondary {
      background: transparent;
      color: var(--white);
      border: 2px solid var(--white);
      padding: 0.85rem 1.75rem;
      font-weight: 600;
      border-radius: 4px;
      text-decoration: none;
      transition: all 0.2s;
    }

    .btn-secondary:hover {
      background: var(--white);
      color: var(--primary);
    }

    /* Services Section & Constrained 2x2 Grid Layout */
    .services-section {
      padding: 5rem 0;
      background-color: var(--bg-dark);
    }

    .services-section h2, 
    .industries-section h2, 
    .workflow-section h2, 
    .advantages-section h2, 
    .faq-section h2 {
      font-family: var(--font-heading);
      font-size: clamp(2rem, 3.5vw, 2.75rem);
      text-transform: uppercase;
      color: var(--white);
      margin-bottom: 0.75rem;
    }

    .section-subtitle {
      color: var(--text-light);
      font-size: 1.1rem;
      margin-bottom: 3rem;
    }

    .services-grid-wrapper {
      max-width: 1100px;
      margin: 0 auto;
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
    }

    @media (max-width: 768px) {
      .services-grid {
        grid-template-columns: 1fr;
      }
    }

    .service-card {
      background: var(--bg-card);
      border-radius: 8px;
      overflow: hidden;
      border: 1px solid var(--border);
      box-shadow: 0 4px 6px -1px rgba(0,0,0,0.2);
      transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .service-card:hover, .service-card:focus-within {
      border-color: var(--accent);
      box-shadow: 0 6px 12px -2px rgba(249, 115, 22, 0.25);
    }

    /* Narrower Image Container Height */
    .service-image {
      width: 100%;
      height: 200px;
      overflow: hidden;
      background: #000;
    }

    .service-image img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .service-content {
      padding: 1.75rem;
    }

    .service-content h3 {
      font-family: var(--font-heading);
      font-size: 1.6rem;
      color: var(--white);
      margin-bottom: 0.75rem;
      text-transform: uppercase;
    }

    .service-content p {
      color: var(--text-light);
      font-size: 0.95rem;
      margin-bottom: 1.25rem;
    }

    .read-more {
      color: var(--accent);
      font-weight: 600;
      text-decoration: none;
    }

    /* Other Grids */
    .industries-grid, .workflow-grid, .advantages-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
    }

    .industries-section, .workflow-section, .advantages-section {
      padding: 5rem 0;
      background-color: var(--bg-dark);
    }

    .industry-card, .workflow-card, .advantage-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 2rem;
      transition: border-color 0.2s ease;
    }

    .industry-card:hover, .workflow-card:hover, .advantage-card:hover {
      border-color: var(--accent);
    }

    .industry-card h3, .workflow-content h3, .advantage-card h3 {
      font-family: var(--font-heading);
      font-size: 1.5rem;
      color: var(--white);
      margin-bottom: 0.75rem;
      text-transform: uppercase;
    }

    .industry-card p, .workflow-content p, .advantage-card p {
      color: var(--text-light);
      font-size: 0.95rem;
      margin-bottom: 1.25rem;
    }

    .industry-icon, .advantage-icon {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      color: var(--accent);
    }

    /* Emergency Banner */
    .emergency-banner-section {
      background: #05080f;
      color: var(--white);
      padding: 4rem 0;
      border-top: 4px solid var(--accent);
      border-bottom: 4px solid var(--accent);
    }

    .emergency-banner-container {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 2rem;
    }

    .emergency-content {
      max-width: 700px;
    }

    .emergency-badge {
      display: inline-block;
      background: var(--accent);
      color: var(--white);
      font-family: var(--font-heading);
      font-size: 0.85rem;
      text-transform: uppercase;
      padding: 0.25rem 0.75rem;
      border-radius: 4px;
      margin-bottom: 1rem;
    }

    .emergency-content h2 {
      font-family: var(--font-heading);
      font-size: clamp(2rem, 3vw, 2.5rem);
      text-transform: uppercase;
      margin-bottom: 0.75rem;
      color: var(--white);
    }

    .emergency-content p {
      color: #cbd5e1;
    }

    .btn-emergency {
      display: inline-flex;
      align-items: center;
      gap: 1rem;
      background: var(--accent);
      color: var(--white);
      padding: 1rem 1.75rem;
      border-radius: 6px;
      text-decoration: none;
      transition: background 0.2s;
    }

    .btn-emergency:hover {
      background: var(--accent-hover);
    }

    .phone-text small {
      display: block;
      font-size: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .phone-text strong {
      font-size: 1.25rem;
      font-family: var(--font-heading);
      letter-spacing: 0.5px;
    }

    .workflow-section {
      background-color: var(--bg-dark);
    }

    .workflow-number {
      font-family: var(--font-heading);
      font-size: 3rem;
      color: var(--accent);
      font-weight: 700;
      line-height: 1;
      margin-bottom: 1rem;
    }

    .workflow-list {
      list-style: none;
      margin-top: 1rem;
    }

    .workflow-list li {
      font-size: 0.9rem;
      color: var(--text-light);
      margin-bottom: 0.5rem;
    }

    /* FAQ */
    .faq-section {
      padding: 5rem 0;
      background-color: var(--bg-dark);
    }

    .faq-container {
      max-width: 900px;
      margin: 0 auto;
    }

    .faq-item {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 6px;
      margin-bottom: 1rem;
      overflow: hidden;
      transition: border-color 0.2s;
    }

    .faq-item:hover {
      border-color: var(--accent);
    }

    .faq-question {
      padding: 1.25rem 1.5rem;
      font-family: var(--font-heading);
      font-size: 1.2rem;
      color: var(--white);
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
      text-transform: uppercase;
    }

    .faq-answer {
      padding: 0 1.5rem 1.5rem;
      color: var(--text-light);
      font-size: 0.95rem;
    }

    /* Footer Fix */
    .site-footer {
      background: var(--black);
      color: #94a3b8;
      padding: 5rem 0 2rem;
      border-top: 4px solid var(--primary);
    }

    .footer-container {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 3rem;
      margin-bottom: 4rem;
    }

    .footer-col h3 {
      font-family: var(--font-heading);
      color: var(--white);
      font-size: 1.25rem;
      text-transform: uppercase;
      margin-bottom: 1.25rem;
    }

    .footer-bio {
      font-size: 0.9rem;
      margin-bottom: 1.5rem;
      line-height: 1.6;
    }

    .footer-iso-badge {
      display: inline-block;
      background: rgba(249, 115, 22, 0.15);
      color: var(--accent);
      border: 1px solid var(--accent);
      padding: 0.35rem 0.85rem;
      border-radius: 4px;
      font-size: 0.85rem;
      font-weight: 600;
    }

    .footer-links, .footer-contact-list {
      list-style: none;
    }

    .footer-links li {
      margin-bottom: 0.75rem;
    }

    .footer-links a {
      color: #94a3b8;
      text-decoration: none;
      transition: color 0.2s;
    }

    .footer-links a:hover {
      color: var(--accent);
    }

    .footer-contact-list li {
      display: flex;
      gap: 0.75rem;
      margin-bottom: 1rem;
      font-size: 0.9rem;
    }

    .footer-contact-list a {
      color: var(--white);
      text-decoration: none;
    }

    .footer-bottom {
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      padding-top: 2rem;
    }

    .footer-bottom-container {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
      font-size: 0.85rem;
    }

    .footer-credit a {
      color: var(--accent);
      text-decoration: none;
    }

    .footer-bottom-links {
      display: flex;
      gap: 1.5rem;
    }

    .footer-bottom-links a {
      color: #94a3b8;
      text-decoration: none;
    }
  </style>

  <!-- Optimized Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700&family=Plus+Jakarta+Sans:wght@400;500;600&display=swap" media="print" onload="this.media='all'">
  <noscript>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@600;700&family=Plus+Jakarta+Sans:wght@400;500;600&display=swap">
  </noscript>
</head>
<body>
  <header class="site-header">
    <div class="container header-container">
      <a href="#" class="logo-link">
        <img src="/uncut-logo-new.avif" alt="Uncut Electro Mechanical Engineering Logo" class="site-logo" width="220" height="55">
      </a>
    </div>
  </header>

<!-- Hero Section -->
<section class="hero-section" style={`background-image: url(${optimizedBg.src});`}>
  <div class="container hero-container">
    <span class="hero-badge">ISO 9001 Aligned • 24/7 Breakdown Support</span>
    <h1>Precision Electro-Mechanical Engineering & Condition Monitoring</h1>
    <p>Industrial engineering partner based in Krugersdorp, delivering expert AC/DC motor rewinding, transformer maintenance, and rapid breakdown response across South Africa.</p>
    <div class="hero-buttons">
      <a href="tel:0795059510" class="btn-primary">Request Emergency Breakdown</a>
      <a href="#services" class="btn-secondary">Explore Our Services</a>
    </div>
  </div>
</section>

<!-- Core Services Section (Constrained 2x2 Grid Layout) -->
<section class="services-section" id="services">
  <div class="container">
    <span class="hero-badge">Industrial Solutions Where You Need It Most</span>
    <h2>Our Core Services</h2>
    <p class="section-subtitle">Precision engineering and heavy industrial maintenance solutions.</p>
    
    <div class="services-grid-wrapper">
      <div class="services-grid">
        
        <!-- Card 1: Transformers & Switchgears -->
        <div class="service-card">
          <div class="service-image">
            <Image src={transformerImg} alt="Transformers and Switchgears" width={600} height={400} loading="lazy" />
          </div>
          <div class="service-content">
            <h3>Transformers & Switchgears</h3>
            <p>Comprehensive maintenance, testing, and overhaul of heavy-duty power transformers and industrial switchgear systems to guarantee grid stability.</p>
            <a href="pages/transformers-switchgears.html" class="read-more">Read More &rarr;</a>
          </div>
        </div>

        <!-- Card 2: Generators & Substations -->
        <div class="service-card">
          <div class="service-image">
            <Image src={generatorImg} alt="Generators and Substations" width={600} height={400} loading="lazy" />
          </div>
          <div class="service-content">
            <h3>Generators & Substations</h3>
            <p>Expert diagnostics, repairs, and preventative maintenance for industrial diesel generators and high-voltage electrical substation infrastructure.</p>
            <a href="pages/generators-substations.html" class="read-more">Read More &rarr;</a>
          </div>
        </div>

        <!-- Card 3: Condition Monitoring -->
        <div class="service-card">
          <div class="service-image">
            <Image src={conditionImg} alt="Condition Monitoring" width={600} height={400} loading="lazy" />
          </div>
          <div class="service-content">
            <h3>Condition Monitoring</h3>
            <p>Advanced predictive maintenance utilizing sensor diagnostics, thermal imaging, and real-time data analysis to prevent unexpected mechanical failures.</p>
            <a href="pages/condition-monitoring.html" class="read-more">Read More &rarr;</a>
          </div>
        </div>

        <!-- Card 4: AC & DC Motor Rewinding -->
        <div class="service-card">
          <div class="service-image">
            <Image src={motorImg} alt="AC and DC Motor Rewinding" width={600} height={400} loading="lazy" />
          </div>
          <div class="service-content">
            <h3>AC & DC Motor Rewinding</h3>
            <p>Precision mechanical overhaul, copper rewinding, and dynamic balancing for industrial AC and DC motors to restore peak operating efficiency.</p>
            <a href="pages/motor-rewinding.html" class="read-more">Read More &rarr;</a>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<!-- Industry Sectors Section -->
<section class="industries-section">
  <div class="container">
    <span class="hero-badge">Markets We Serve</span>
    <h2>Powering Heavy Industry Across South Africa</h2>
    <p class="section-subtitle">Reliable engineering solutions engineered for the most demanding operating environments.</p>
    
    <div class="industries-grid">
      <div class="industry-card">
        <div class="industry-icon">⛏️</div>
        <h3>Mining & Minerals Processing</h3>
        <p>Keeping extraction, crushing, and conveyor systems running with rugged high-capacity motor repairs, emergency transformer overhauls, and rigorous electrical testing.</p>
      </div>

      <div class="industry-card">
        <div class="industry-icon">⚡</div>
        <h3>Power Generation & Distribution</h3>
        <p>Ensuring grid reliability and continuous plant output through expert high-voltage substation maintenance, switchgear diagnostics, and specialized transformer servicing.</p>
      </div>

      <div class="industry-card">
        <div class="industry-icon">🏭</div>
        <h3>Heavy Manufacturing</h3>
        <p>Minimizing costly factory downtime with rapid-turnaround AC and DC motor rewinding, dynamic balancing, and comprehensive mechanical overhauls.</p>
      </div>

      <div class="industry-card">
        <div class="industry-icon">💧</div>
        <h3>Municipal Infrastructure & Utilities</h3>
        <p>Supporting vital public services, water treatment facilities, and regional pumping stations with dependable electro-mechanical maintenance and 24/7 breakdown support.</p>
      </div>

      <div class="industry-card">
        <div class="industry-icon">⛽</div>
        <h3>Petrochemical & Heavy Process</h3>
        <p>Delivering precision maintenance and advanced condition monitoring adhering to stringent safety compliance requirements for continuous chemical processing.</p>
      </div>

      <div class="industry-card">
        <div class="industry-icon">⚙️</div>
        <h3>General Industrial Engineering</h3>
        <p>Providing custom industrial engineering diagnostics, thermal imaging, and preventative maintenance strategies tailored to unique plant specifications.</p>
      </div>
    </div>
  </div>
</section>

<!-- Emergency Breakdown Banner -->
<section class="emergency-banner-section">
  <div class="container emergency-banner-container">
    <div class="emergency-content">
      <span class="emergency-badge">24/7 Rapid Response</span>
      <h2>Plant Down? Unplanned Outage?</h2>
      <p>We provide around-the-clock emergency electrical and mechanical breakdown support across South Africa. Minimize downtime with our rapid-dispatch engineering teams.</p>
    </div>
    <div class="emergency-action">
      <a href="tel:0795059510" class="btn-emergency">
        <span class="phone-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
          </svg>
        </span>
        <div class="phone-text">
          <small>Call Emergency Line</small>
          <strong>079 505 9510</strong>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- Workflow Section -->
<section class="workflow-section">
  <div class="container">
    <span class="hero-badge">Our Operational Process</span>
    <h2>Engineered for Precision & Speed</h2>
    <p class="section-subtitle">A transparent, rigorous 3-step methodology designed to eliminate unexpected failures.</p>
    
    <div class="workflow-grid">
      <div class="workflow-card">
        <div class="workflow-number">01</div>
        <div class="workflow-content">
          <h3>Rapid Diagnosis & Inspection</h3>
          <p>We deploy advanced diagnostic tooling, performing mechanical teardowns, electrical insulation testing, and thermal imaging to isolate root causes.</p>
          <ul class="workflow-list">
            <li>✓ On-site or workshop fault-finding</li>
            <li>✓ Insulation resistance & surge testing</li>
            <li>✓ Detailed engineering assessment report</li>
          </ul>
        </div>
      </div>

      <div class="workflow-card">
        <div class="workflow-number">02</div>
        <div class="workflow-content">
          <h3>Precision Overhaul & Repair</h3>
          <p>Equipment is routed to our workshop bays for complete copper rewinding, VPI treatment, or critical mechanical machining.</p>
          <ul class="workflow-list">
            <li>✓ Specialized copper winding & balancing</li>
            <li>✓ Transformer oil processing & rewinding</li>
            <li>✓ Switchgear and substation retrofits</li>
          </ul>
        </div>
      </div>

      <div class="workflow-card">
        <div class="workflow-number">03</div>
        <div class="workflow-content">
          <h3>Rigorous Testing & Recommissioning</h3>
          <p>Units undergo extensive full-load and safety testing to ensure complete performance verification before recommissioning.</p>
          <ul class="workflow-list">
            <li>✓ Dynamic load & performance testing</li>
            <li>✓ Quality assurance & safety sign-off</li>
            <li>✓ Rapid dispatch & installation support</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Why Choose Us Section -->
<section class="advantages-section">
  <div class="container">
    <span class="hero-badge">The Uncut Advantage</span>
    <h2>Why Heavy Industry Partners With Us</h2>
    <p class="section-subtitle">Decades of combined electro-mechanical expertise and rapid-response dispatch.</p>
    
    <div class="advantages-grid">
      <div class="advantage-card">
        <h3>Rapid Breakdown Response</h3>
        <p>Dedicated engineering teams on standby 24/7 for emergency dispatch across South Africa.</p>
      </div>
      <div class="advantage-card">
        <h3>Advanced Workshop Facility</h3>
