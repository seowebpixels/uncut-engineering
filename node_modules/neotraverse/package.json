{
  "name": "neotraverse",
  "version": "1.0.1",
  "description": "traverse and transform objects by visiting every node on a recursive walk",
  "keywords": [
    "clone",
    "deep",
    "forEach",
    "map",
    "recursive",
    "traverse",
    "walk"
  ],
  "homepage": "https://neotraverse.puruvj.dev",
  "license": "MIT",
  "author": {
    "name": "Puru Vijay",
    "url": "https://puruvj.dev"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PuruVJ/neotraverse.git",
    "directory": "packages/neotraverse"
  },
  "files": [
    "dist",
    "legacy.*"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/legacy/legacy.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./modern": {
      "types": "./dist/modern.d.ts",
      "default": "./dist/modern.js"
    },
    "./safe": {
      "types": "./dist/safe/index.d.ts",
      "default": "./dist/safe/index.js"
    },
    "./legacy": {
      "require": {
        "types": "./dist/legacy/legacy.d.cts",
        "default": "./dist/legacy/legacy.cjs"
      },
      "import": {
        "types": "./dist/legacy/legacy.d.ts",
        "default": "./dist/legacy/legacy.mjs"
      },
      "default": "./dist/legacy/legacy.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "provenance": true
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tinybench": "^6.0.2",
    "traverse": "^0.6.11",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">= 10"
  },
  "scripts": {
    "compile": "vp pack",
    "test": "vp test",
    "test:cov": "vp test --coverage",
    "bench": "pnpm compile && node --expose-gc --max-semi-space-size=128 --import tsx bench/run.ts",
    "bench:safe": "pnpm compile && node --expose-gc --max-semi-space-size=128 --import tsx bench/run-safe.ts",
    "bench:safe-memory": "pnpm compile && node --expose-gc --max-semi-space-size=128 --import tsx bench/safe-memory.ts",
    "typecheck": "tsc --noEmit",
    "test:types": "vp test --typecheck",
    "bundle-size": "node scripts/measure-bundle.mjs"
  }
}